{
  "name": "@kud/mcp-gtv",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Google TV — control paired devices (keys, text, app launch) via @kud/gtv.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-tv",
    "android-tv",
    "remote-control"
  ],
  "license": "MIT",
  "author": "Erwann Mest <m@kud.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kud/mcp-gtv.git"
  },
  "homepage": "https://github.com/kud/mcp-gtv#readme",
  "bugs": {
    "url": "https://github.com/kud/mcp-gtv/issues"
  },
  "bin": {
    "mcp-gtv": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@kud/gtv": "0.1.2",
    "@modelcontextprotocol/sdk": "1.27.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
